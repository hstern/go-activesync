# Editor settings shared across the project. https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown uses two trailing spaces for <br>

[*.{sh,bash}]
indent_size = 4

[*.php]
indent_size = 4
